{
  "name": "copilot-price-league-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Tiny Cloudflare Worker + D1 backend for the copilot-price friends leaderboard",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "init-db-local": "wrangler d1 execute copilot-price-league --local --file=./schema.sql",
    "init-db": "wrangler d1 execute copilot-price-league --remote --file=./schema.sql",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "wrangler": "^3.99.0"
  }
}
